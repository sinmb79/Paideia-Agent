{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sinmb79/Paideia-Agent/schemas/reasoning_ledger_candidate.v1.schema.json",
  "title": "Paideia Reasoning Ledger Candidate",
  "type": "object",
  "required": [
    "schema",
    "created_at_utc",
    "candidate_type",
    "employment_id",
    "agent_name",
    "objective",
    "candidate_principles",
    "policy"
  ],
  "properties": {
    "schema": { "const": "paideia-reasoning-ledger-candidate/v1" },
    "created_at_utc": { "type": "string" },
    "candidate_type": { "type": "string", "minLength": 1 },
    "source_experience_id": { "type": ["string", "null"] },
    "employment_id": { "type": "string", "minLength": 1 },
    "agent_name": { "type": "string", "minLength": 1 },
    "objective": { "type": "string", "minLength": 1 },
    "episode_id": { "type": ["string", "null"] },
    "scenario_id": { "type": ["string", "null"] },
    "review_summary": { "type": ["string", "null"] },
    "learning_signal": { "type": ["string", "null"] },
    "score": { "type": ["number", "integer", "null"] },
    "quality_label": { "type": "object" },
    "candidate_principles": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string", "minLength": 1 }
    },
    "policy": {
      "type": "object",
      "required": [
        "automatic_promotion_performed",
        "boss_review_required",
        "private_reasoning_trace"
      ],
      "properties": {
        "automatic_promotion_performed": { "const": false },
        "boss_review_required": { "const": true },
        "boss_review_applied": { "type": "boolean" },
        "private_reasoning_trace": { "const": "do_not_store" },
        "full_rollout_replay_stored": { "type": "boolean" },
        "separate_consciousness_created": { "type": "boolean" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
