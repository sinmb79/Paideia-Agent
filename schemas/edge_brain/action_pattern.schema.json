{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sinmb79/Paideia-Agent/schemas/edge_brain/action_pattern.schema.json",
  "title": "Paideia Edge Action Pattern",
  "type": "object",
  "required": ["schema", "action_pattern_id", "version", "source_pattern_id", "source_kibo_ids", "owner", "domain", "task_family", "required_observations", "required_capabilities", "preconditions", "invariants", "postconditions", "steps", "start_step_id", "max_total_duration_ms", "cognitive_budget", "autonomy_envelope", "learning_status", "deployment_status", "evidence_refs", "content_digest"],
  "properties": {
    "schema": { "const": "paideia-edge-action-pattern/v1" },
    "action_pattern_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "source_pattern_id": { "type": "string", "minLength": 1 },
    "source_kibo_ids": { "type": "array", "items": { "type": "string" } },
    "owner": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "task_family": { "type": "string", "minLength": 1 },
    "required_observations": { "type": "array", "items": { "type": "string" } },
    "required_capabilities": { "type": "array", "items": { "type": "string" } },
    "preconditions": { "type": "array", "items": { "type": "object" } },
    "invariants": { "type": "array", "items": { "type": "object" } },
    "postconditions": { "type": "array", "items": { "type": "object" } },
    "steps": { "type": "array", "minItems": 1, "items": { "$ref": "#/$defs/action_step" } },
    "start_step_id": { "type": "string", "minLength": 1 },
    "max_total_duration_ms": { "type": "integer", "minimum": 0 },
    "cognitive_budget": { "$ref": "#/$defs/cognitive_budget" },
    "autonomy_envelope": { "$ref": "#/$defs/autonomy_envelope" },
    "learning_status": { "enum": ["draft", "exam_validated", "field_validated", "reinforced", "weakened", "quarantined"] },
    "deployment_status": { "enum": ["not_compiled", "compiled", "simulation_validated", "shadow_validated", "limited_field", "operational", "suspended", "revoked"] },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "content_digest": { "type": "string" }
  },
  "$defs": {
    "action_step": {
      "type": "object",
      "required": ["step_id", "kind", "capability_id", "input_bindings", "guard", "success_condition", "timeout_ms", "max_attempts", "on_success", "on_failure", "fallback_step_id", "approval_scope"],
      "properties": {
        "step_id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "minLength": 1 },
        "capability_id": { "type": ["string", "null"] },
        "input_bindings": { "type": "array", "items": { "type": "object" } },
        "guard": { "type": ["object", "null"] },
        "success_condition": { "type": ["object", "null"] },
        "timeout_ms": { "type": "integer", "minimum": 0 },
        "max_attempts": { "type": "integer", "minimum": 1 },
        "on_success": { "type": ["string", "null"] },
        "on_failure": { "type": ["string", "null"] },
        "fallback_step_id": { "type": ["string", "null"] },
        "approval_scope": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },
    "cognitive_budget": {
      "type": "object",
      "required": ["max_cycle_ms", "max_local_model_tokens", "max_remote_model_tokens", "max_energy_units", "max_memory_mb", "network_allowed", "remote_calls_allowed"],
      "properties": {
        "max_cycle_ms": { "type": "integer", "minimum": 0 },
        "max_local_model_tokens": { "type": "integer", "minimum": 0 },
        "max_remote_model_tokens": { "type": "integer", "minimum": 0 },
        "max_energy_units": { "type": ["number", "null"], "minimum": 0 },
        "max_memory_mb": { "type": ["integer", "null"], "minimum": 0 },
        "network_allowed": { "type": "boolean" },
        "remote_calls_allowed": { "type": "integer", "minimum": 0 }
      },
      "additionalProperties": false
    },
    "autonomy_envelope": {
      "type": "object",
      "required": ["envelope_id", "allowed_capabilities", "prohibited_capabilities", "allowed_side_effect_classes", "max_operation_duration_ms", "required_health_signals", "abort_conditions", "human_approval_scopes", "offline_policy"],
      "properties": {
        "envelope_id": { "type": "string", "minLength": 1 },
        "allowed_capabilities": { "type": "array", "items": { "type": "string" } },
        "prohibited_capabilities": { "type": "array", "items": { "type": "string" } },
        "allowed_side_effect_classes": { "type": "array", "items": { "enum": ["read_only", "reversible", "consequential", "safety_critical", "prohibited"] } },
        "max_operation_duration_ms": { "type": "integer", "minimum": 0 },
        "required_health_signals": { "type": "array", "items": { "type": "string" } },
        "abort_conditions": { "type": "array", "items": { "type": "object" } },
        "human_approval_scopes": { "type": "array", "items": { "type": "string" } },
        "offline_policy": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
