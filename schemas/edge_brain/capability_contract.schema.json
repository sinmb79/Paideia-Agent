{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sinmb79/Paideia-Agent/schemas/edge_brain/capability_contract.schema.json",
  "title": "Paideia Edge Capability Contract",
  "type": "object",
  "required": ["schema", "capability_id", "version", "input_schema_ref", "output_schema_ref", "side_effect_class", "required_permissions", "idempotent", "reversible", "timeout_ms", "simulator_adapter", "runtime_adapter", "safe_fallback_capability_id"],
  "properties": {
    "schema": { "const": "paideia-edge-capability-contract/v1" },
    "capability_id": { "type": "string", "minLength": 1 },
    "version": { "type": "string", "minLength": 1 },
    "input_schema_ref": { "type": "string" },
    "output_schema_ref": { "type": "string" },
    "side_effect_class": { "enum": ["read_only", "reversible", "consequential", "safety_critical", "prohibited"] },
    "required_permissions": { "type": "array", "items": { "type": "string" } },
    "idempotent": { "type": "boolean" },
    "reversible": { "type": "boolean" },
    "timeout_ms": { "type": "integer", "minimum": 0 },
    "simulator_adapter": { "type": "string" },
    "runtime_adapter": { "type": ["string", "null"] },
    "safe_fallback_capability_id": { "type": ["string", "null"] }
  },
  "additionalProperties": false
}
