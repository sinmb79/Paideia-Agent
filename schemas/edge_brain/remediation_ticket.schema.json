{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sinmb79/Paideia-Agent/schemas/edge_brain/remediation_ticket.schema.json",
  "title": "Paideia Edge Remediation Ticket",
  "type": "object",
  "required": ["schema", "ticket_id", "weakness_id", "affected_pattern_ids", "affected_action_pattern_ids", "required_curriculum_units", "required_exam_kinds", "required_score", "blocks_operational_use", "status"],
  "properties": {
    "schema": { "const": "paideia-edge-remediation-ticket/v1" },
    "ticket_id": { "type": "string", "minLength": 1 },
    "weakness_id": { "type": "string", "minLength": 1 },
    "affected_pattern_ids": { "type": "array", "items": { "type": "string" } },
    "affected_action_pattern_ids": { "type": "array", "items": { "type": "string" } },
    "required_curriculum_units": { "type": "array", "items": { "type": "string" } },
    "required_exam_kinds": { "type": "array", "items": { "type": "string" } },
    "required_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "blocks_operational_use": { "type": "boolean" },
    "status": { "enum": ["open", "planned", "in_progress", "reexam_required", "completed", "blocked", "closed"] }
  },
  "additionalProperties": false
}
