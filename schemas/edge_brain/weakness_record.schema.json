{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sinmb79/Paideia-Agent/schemas/edge_brain/weakness_record.schema.json",
  "title": "Paideia Edge Weakness Record",
  "type": "object",
  "required": ["schema", "weakness_id", "owner", "domain", "skill_id", "weakness_type", "evidence_refs", "severity", "recurrence_count", "status"],
  "properties": {
    "schema": { "const": "paideia-edge-weakness-record/v1" },
    "weakness_id": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "skill_id": { "type": "string", "minLength": 1 },
    "weakness_type": { "enum": ["knowledge_gap", "reasoning_gap", "risk_gap", "transfer_gap", "freshness_gap", "counterargument_gap", "capability_gap", "execution_gap", "safety_gap", "world_model_gap"] },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "severity": { "type": "number", "minimum": 0, "maximum": 1 },
    "recurrence_count": { "type": "integer", "minimum": 0 },
    "status": { "enum": ["open", "under_remediation", "reexam_required", "resolved", "accepted_risk"] }
  },
  "additionalProperties": false
}
