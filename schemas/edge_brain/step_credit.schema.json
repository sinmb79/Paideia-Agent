{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sinmb79/Paideia-Agent/schemas/edge_brain/step_credit.schema.json",
  "title": "Paideia Edge Step Credit",
  "type": "object",
  "required": ["schema", "outcome_id", "step_id", "contribution_score", "causal_confidence", "reason_codes"],
  "properties": {
    "schema": { "const": "paideia-edge-step-credit/v1" },
    "outcome_id": { "type": "string", "minLength": 1 },
    "step_id": { "type": "string", "minLength": 1 },
    "contribution_score": { "type": "number", "minimum": -1, "maximum": 1 },
    "causal_confidence": { "type": "number", "minimum": 0, "maximum": 1 },
    "reason_codes": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
