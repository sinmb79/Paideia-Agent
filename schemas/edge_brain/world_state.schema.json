{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sinmb79/Paideia-Agent/schemas/edge_brain/world_state.schema.json",
  "title": "Paideia Edge World State",
  "type": "object",
  "required": ["schema", "state_id", "created_at", "facts", "environment_tags", "sensor_health", "state_digest"],
  "properties": {
    "schema": { "const": "paideia-edge-world-state/v1" },
    "state_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "minLength": 1 },
    "facts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["key", "value", "confidence", "source_observation_ids", "valid_until"],
        "properties": {
          "key": { "type": "string", "minLength": 1 },
          "value": true,
          "confidence": { "type": "number", "minimum": 0, "maximum": 1 },
          "source_observation_ids": { "type": "array", "items": { "type": "string" } },
          "valid_until": { "type": ["string", "null"] }
        },
        "additionalProperties": false
      }
    },
    "environment_tags": { "type": "array", "items": { "type": "string" } },
    "sensor_health": { "type": "array", "items": { "type": "string" } },
    "state_digest": { "type": "string" }
  },
  "additionalProperties": false
}
