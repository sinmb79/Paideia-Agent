{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sinmb79/Paideia-Agent/schemas/kibo_record.v1.schema.json",
  "title": "Paideia Kibo Record",
  "type": "object",
  "required": [
    "schema",
    "kibo_id",
    "source_run_id",
    "owner",
    "domain",
    "task_type",
    "problem_signature",
    "solution_steps",
    "reusable_logic",
    "failure_modes",
    "required_inputs",
    "output_template",
    "evidence_refs",
    "success_score",
    "promotion_status",
    "created_at",
    "updated_at"
  ],
  "properties": {
    "schema": { "const": "paideia-kibo-record/v1" },
    "kibo_id": { "type": "string", "minLength": 1 },
    "source_run_id": { "type": "string" },
    "owner": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "task_type": { "type": "string", "minLength": 1 },
    "problem_signature": { "type": "string" },
    "solution_steps": { "type": "array", "items": { "type": "string" } },
    "reusable_logic": { "type": "array", "items": { "type": "string" } },
    "failure_modes": { "type": "array", "items": { "type": "string" } },
    "required_inputs": { "type": "array", "items": { "type": "string" } },
    "output_template": { "type": "string" },
    "evidence_refs": { "type": "array", "items": { "type": "string" } },
    "success_score": { "type": "integer", "minimum": 0, "maximum": 100 },
    "promotion_status": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string" },
    "updated_at": { "type": "string" },
    "last_used_at": { "type": "string" },
    "caveats": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
