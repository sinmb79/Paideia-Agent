{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sinmb79/Paideia-Agent/schemas/adaptive_exam.v1.schema.json",
  "title": "Paideia Adaptive Exam",
  "type": "object",
  "required": [
    "schema",
    "exam_id",
    "curriculum_id",
    "difficulty",
    "questions"
  ],
  "properties": {
    "schema": { "const": "paideia-adaptive-exam/v1" },
    "exam_id": { "type": "string", "minLength": 1 },
    "curriculum_id": { "type": "string", "minLength": 1 },
    "difficulty": {
      "enum": ["maintenance", "standard", "advanced", "remediation"]
    },
    "questions": {
      "type": "array",
      "minItems": 1,
      "items": { "type": "string" }
    }
  },
  "additionalProperties": false
}
