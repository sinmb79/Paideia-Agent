{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sinmb79/Paideia-Agent/schemas/pattern_candidate.v1.schema.json",
  "title": "Paideia Pattern Candidate",
  "type": "object",
  "required": [
    "schema",
    "pattern_id",
    "owner",
    "domain",
    "task_family",
    "abstract_strategy",
    "required_conditions",
    "known_failure_modes",
    "source_kibo_ids",
    "exam_score",
    "real_world_score",
    "reinforcement_score",
    "status"
  ],
  "properties": {
    "schema": { "const": "paideia-pattern-candidate/v1" },
    "pattern_id": { "type": "string", "minLength": 1 },
    "owner": { "type": "string", "minLength": 1 },
    "domain": { "type": "string", "minLength": 1 },
    "task_family": { "type": "string", "minLength": 1 },
    "abstract_strategy": { "type": "array", "items": { "type": "string" } },
    "required_conditions": { "type": "array", "items": { "type": "string" } },
    "known_failure_modes": { "type": "array", "items": { "type": "string" } },
    "source_kibo_ids": { "type": "array", "minItems": 1, "items": { "type": "string" } },
    "exam_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "real_world_score": { "type": ["number", "null"], "minimum": 0, "maximum": 1 },
    "reinforcement_score": { "type": "number", "minimum": 0, "maximum": 1 },
    "status": {
      "enum": [
        "draft",
        "exam_validated",
        "field_validated",
        "reinforced",
        "weakened",
        "quarantined"
      ]
    }
  },
  "additionalProperties": false
}
