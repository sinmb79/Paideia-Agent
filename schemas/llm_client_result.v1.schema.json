{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sinmb79/Paideia-Agent/schemas/llm_client_result.v1.schema.json",
  "title": "Paideia LLM Client Result",
  "type": "object",
  "required": ["schema", "engine", "status", "identity_policy"],
  "properties": {
    "schema": { "const": "paideia-llm-client-result/v1" },
    "engine": { "type": "string", "minLength": 1 },
    "status": {
      "enum": [
        "completed",
        "unavailable",
        "bridge_context_prepared",
        "adapter_manifest_ready"
      ]
    },
    "text": { "type": "string" },
    "reason": { "type": "string" },
    "identity_policy": { "const": "application_engine_not_identity" },
    "raw_output_saved": { "type": "boolean" },
    "network_access": { "type": "string" },
    "private_reasoning_trace": { "enum": ["do_not_store", "omitted"] }
  },
  "additionalProperties": true
}
