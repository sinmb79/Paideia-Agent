{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sinmb79/Paideia-Agent/schemas/skill_graph.v1.schema.json",
  "title": "Paideia Skill Graph",
  "type": "object",
  "required": ["schema", "nodes", "edges"],
  "properties": {
    "schema": { "const": "paideia-skill-graph/v1" },
    "nodes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["skill_id", "name", "domain", "mastery_score"],
        "properties": {
          "schema": { "const": "paideia-skill-node/v1" },
          "skill_id": { "type": "string", "minLength": 1 },
          "name": { "type": "string", "minLength": 1 },
          "domain": { "type": "string", "minLength": 1 },
          "mastery_score": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    },
    "edges": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["from_skill", "to_skill", "relation", "weight"],
        "properties": {
          "schema": { "const": "paideia-skill-edge/v1" },
          "from_skill": { "type": "string", "minLength": 1 },
          "to_skill": { "type": "string", "minLength": 1 },
          "relation": { "type": "string", "minLength": 1 },
          "weight": { "type": "number", "minimum": 0, "maximum": 1 }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
