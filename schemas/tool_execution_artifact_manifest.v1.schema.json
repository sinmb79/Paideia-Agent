{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sinmb79/Paideia-Agent/schemas/tool_execution_artifact_manifest.v1.schema.json",
  "title": "Paideia Tool Execution Artifact Manifest",
  "type": "object",
  "required": ["schema", "status", "artifact_count", "artifacts", "public_safe"],
  "properties": {
    "schema": { "const": "paideia-tool-execution-artifact-manifest/v1" },
    "created_at_utc": { "type": "string" },
    "status": { "enum": ["materialized", "no_tool_results", "not_requested"] },
    "artifact_root": { "type": "string" },
    "artifact_count": { "type": "integer", "minimum": 0 },
    "manifest_file": { "type": "string" },
    "manifest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "artifacts": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["tool", "status", "relative_path", "bytes", "sha256"],
        "properties": {
          "tool": { "type": "string", "minLength": 1 },
          "status": { "type": "string" },
          "relative_path": {
            "type": "string",
            "minLength": 1,
            "not": { "pattern": "^(?:[A-Za-z]:|/|.*\\.\\..*)"}
          },
          "bytes": { "type": "integer", "minimum": 0 },
          "sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
          "output_digest_sha256": { "type": "string", "pattern": "^[a-f0-9]{64}$" }
        },
        "additionalProperties": true
      }
    },
    "public_safe": {
      "type": "object",
      "required": [
        "network_call_performed",
        "subprocess_executed",
        "external_side_effects_performed",
        "raw_provider_payload_saved",
        "private_reasoning_trace",
        "absolute_paths_exported"
      ],
      "properties": {
        "network_call_performed": { "const": false },
        "subprocess_executed": { "const": false },
        "external_side_effects_performed": { "const": false },
        "raw_provider_payload_saved": { "const": false },
        "private_reasoning_trace": { "const": "do_not_store" },
        "absolute_paths_exported": { "const": false }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
