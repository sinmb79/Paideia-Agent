{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/sinmb79/Paideia-Agent/schemas/user_decision_model.v1.schema.json",
  "title": "Paideia User Decision Model",
  "type": "object",
  "required": [
    "schema",
    "owner",
    "preferred_output_style",
    "risk_preference",
    "decision_biases",
    "recurring_priorities",
    "rejected_patterns",
    "favored_patterns"
  ],
  "properties": {
    "schema": { "const": "paideia-user-decision-model/v1" },
    "owner": { "type": "string", "minLength": 1 },
    "preferred_output_style": { "type": "array", "items": { "type": "string" } },
    "risk_preference": { "type": "string" },
    "decision_biases": { "type": "array", "items": { "type": "string" } },
    "recurring_priorities": { "type": "array", "items": { "type": "string" } },
    "rejected_patterns": { "type": "array", "items": { "type": "string" } },
    "favored_patterns": { "type": "array", "items": { "type": "string" } }
  },
  "additionalProperties": false
}
